          flirt: "Want to see my rocket? It's reusable for you. Let's go to Mars and start a civilization together!"
        },
        'Charles Hoskinson': {
          roast: "Needs 5 more years of peer review. I've written 47 papers on why this won't work.",
          flirt: "I've published a whitepaper on our compatibility. The mathematics check out perfectly."
        },
        'William Shakespeare': {
          roast: "Thou art a boil, a plague sore, an embossed carbuncle! Away, thou damned doorkeeper!",
          flirt: "Shall I compare thee to a summer's day? Thou art more lovely and more temperate."
        },
        'Albert Einstein': {
          roast: "Your approach moves slower than light in a black hole. E=mc², your game equals zero.",
          flirt: "Time dilates when I'm with you... in a good way. Our attraction is stronger than gravity."
        },
        'Catherine the Great': {
          roast: "You offer me WHAT? You're not fit to polish my throne! My horse has more grace.",
          flirt: "I conquered half of Europe, but you've conquered me completely. Come to my Winter Palace tonight."
        },
